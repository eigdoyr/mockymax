{
  "name": "@mockymax/scene-format",
  "version": "0.1.0",
  "private": true,
  "description": "Type-safe definition and validation for MockyMax scene manifests.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "prettier": "^3.3.0",
    "typescript": "~5.7.0"
  }
}
